{
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.9"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "main.py"
    }
  ],
  "excludeFiles": [
    "tests/**",
    "debugs/**",
    "env/**",
    "test_venv/**",
    "test_vercel_env/**",
    "*.whl",
    "*.pyc",
    "__pycache__/**",
    ".gitignore",
    "README.md",
    "openBB.md",
    "railway.json",
    "runtime.txt",
    "start.sh",
    "test_cache.py",
    "test_cache_debug.py"
  ]
}